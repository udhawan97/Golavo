{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "unicorn", "oxc"],
  "env": {
    "browser": true,
    "es2022": true
  },
  "ignorePatterns": [
    "dist",
    "coverage",
    "playwright-report",
    "test-results",
    "src/mocks"
  ],
  "rules": {
    "react-hooks/exhaustive-deps": "warn",
    "react-hooks/rules-of-hooks": "error",
    "typescript/no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "caughtErrorsIgnorePattern": "^_"
      }
    ]
  },
  "overrides": [
    {
      // useAsync takes the caller's dependency array, so it can never be an
      // array literal here. oxlint honours no inline disable for this rule,
      // so it is scoped off for this one file.
      "files": ["src/lib/hooks.ts"],
      "rules": {
        "react-hooks/exhaustive-deps": "off"
      }
    },
    {
      // Resetting an error boundary on a prop change is what componentDidUpdate
      // is for, and the change-and-error double guard makes re-entry impossible.
      // Rewriting untested crash-recovery to satisfy a style rule is the worse
      // trade.
      "files": ["src/components/ErrorBoundary.tsx"],
      "rules": {
        "react/no-did-update-set-state": "off"
      }
    },
    {
      "files": ["**/*.test.ts", "**/*.test.tsx", "tests/**/*.ts"],
      "env": {
        "node": true
      },
      "rules": {
        "typescript/no-explicit-any": "off"
      }
    }
  ]
}
