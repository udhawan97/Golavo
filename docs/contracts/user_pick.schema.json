{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://udhawan97.github.io/Golavo/contracts/user-pick-0.1.0.schema.json",
  "title": "Golavo user picks",
  "description": "Mutable pre-kickoff drafts, immutable locked calls, and computed scored or void views.",
  "oneOf": [
    {"$ref": "#/$defs/UserPick"},
    {"$ref": "#/$defs/PickView"},
    {"$ref": "#/$defs/PicksListResponse"},
    {"$ref": "#/$defs/PicksSummary"}
  ],
  "$defs": {
    "Score": {
      "type": "object",
      "additionalProperties": false,
      "required": ["home_goals", "away_goals"],
      "properties": {
        "home_goals": {"type": "integer", "minimum": 0, "maximum": 20},
        "away_goals": {"type": "integer", "minimum": 0, "maximum": 20}
      }
    },
    "UserCall": {
      "type": "object",
      "additionalProperties": false,
      "required": ["home_goals", "away_goals", "outcome"],
      "properties": {
        "home_goals": {"type": "integer", "minimum": 0, "maximum": 20},
        "away_goals": {"type": "integer", "minimum": 0, "maximum": 20},
        "outcome": {"enum": ["home", "draw", "away"]}
      }
    },
    "MatchSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["match_id", "kickoff_utc", "kickoff_time_known", "home_team", "away_team", "home_norm", "away_norm", "competition"],
      "properties": {
        "match_id": {"type": "string", "minLength": 1},
        "kickoff_utc": {"type": "string", "format": "date-time"},
        "kickoff_time_known": {"type": "boolean"},
        "home_team": {"type": "string", "minLength": 1},
        "away_team": {"type": "string", "minLength": 1},
        "home_norm": {"type": "string", "minLength": 1},
        "away_norm": {"type": "string", "minLength": 1},
        "competition": {"type": ["string", "null"]}
      }
    },
    "AnalysisFingerprint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index_fingerprint", "analysis_schema_version", "information_cutoff_utc"],
      "properties": {
        "index_fingerprint": {"type": "string", "minLength": 1},
        "analysis_schema_version": {"type": "string", "minLength": 1},
        "information_cutoff_utc": {"type": "string", "format": "date-time"}
      }
    },
    "RivalModel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "capability", "score_pick", "outcome_pick"],
      "properties": {
        "family": {"enum": ["climatological", "elo_ordlogit", "poisson_independent", "dixon_coles", "bivariate_poisson"]},
        "capability": {"enum": ["score", "outcome_only", "abstained"]},
        "score_pick": {"oneOf": [{"$ref": "#/$defs/Score"}, {"type": "null"}]},
        "outcome_pick": {"type": ["string", "null"], "enum": ["home", "draw", "away", null]}
      },
      "allOf": [
        {
          "if": {"properties": {"capability": {"const": "score"}}},
          "then": {
            "properties": {
              "score_pick": {"$ref": "#/$defs/Score"},
              "outcome_pick": {"enum": ["home", "draw", "away"]}
            }
          }
        },
        {
          "if": {"properties": {"capability": {"const": "outcome_only"}}},
          "then": {
            "properties": {
              "score_pick": {"type": "null"},
              "outcome_pick": {"enum": ["home", "draw", "away"]}
            }
          }
        },
        {
          "if": {"properties": {"capability": {"const": "abstained"}}},
          "then": {
            "properties": {
              "score_pick": {"type": "null"},
              "outcome_pick": {"type": "null"}
            }
          }
        }
      ]
    },
    "UserPick": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "pick_id", "status", "match", "user_pick", "rivals", "analysis_fingerprint", "created_at_utc", "updated_at_utc", "lock_at_utc", "locked_at_utc", "payload_sha256"],
      "properties": {
        "schema_version": {"const": "0.1.0"},
        "pick_id": {"type": ["string", "null"], "pattern": "^pk_[a-f0-9]{20}$"},
        "status": {"enum": ["draft", "locked"]},
        "match": {"$ref": "#/$defs/MatchSnapshot"},
        "user_pick": {"$ref": "#/$defs/UserCall"},
        "rivals": {"type": "array", "maxItems": 5, "items": {"$ref": "#/$defs/RivalModel"}},
        "analysis_fingerprint": {"$ref": "#/$defs/AnalysisFingerprint"},
        "created_at_utc": {"type": "string", "format": "date-time"},
        "updated_at_utc": {"type": "string", "format": "date-time"},
        "lock_at_utc": {"type": "string", "format": "date-time"},
        "locked_at_utc": {"type": ["string", "null"], "format": "date-time"},
        "payload_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"}
      },
      "oneOf": [
        {
          "properties": {
            "status": {"const": "draft"},
            "pick_id": {"type": "null"},
            "locked_at_utc": {"type": "null"},
            "payload_sha256": {"type": "null"}
          }
        },
        {
          "properties": {
            "status": {"const": "locked"},
            "pick_id": {"type": "string", "pattern": "^pk_[a-f0-9]{20}$"},
            "locked_at_utc": {"type": "string", "format": "date-time"},
            "payload_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
          }
        }
      ]
    },
    "Result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["home_goals", "away_goals", "outcome"],
      "properties": {
        "home_goals": {"type": "integer", "minimum": 0},
        "away_goals": {"type": "integer", "minimum": 0},
        "outcome": {"enum": ["home", "draw", "away"]}
      }
    },
    "PickPoints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exact", "outcome", "total"],
      "properties": {
        "exact": {"type": "integer", "minimum": 0, "maximum": 3},
        "outcome": {"type": "integer", "minimum": 0, "maximum": 1},
        "total": {"type": "integer", "minimum": 0, "maximum": 4}
      }
    },
    "UserPoints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exact", "outcome", "bonus", "total"],
      "properties": {
        "exact": {"type": "integer", "minimum": 0, "maximum": 3},
        "outcome": {"type": "integer", "minimum": 0, "maximum": 1},
        "bonus": {"type": "integer", "minimum": 0, "maximum": 1},
        "total": {"type": "integer", "minimum": 0, "maximum": 5}
      }
    },
    "RivalPoints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "exact", "outcome", "total"],
      "properties": {
        "family": {"type": "string", "minLength": 1},
        "exact": {"type": "integer", "minimum": 0, "maximum": 3},
        "outcome": {"type": "integer", "minimum": 0, "maximum": 1},
        "total": {"type": "integer", "minimum": 0, "maximum": 4}
      }
    },
    "PickScoring": {
      "type": "object",
      "additionalProperties": false,
      "required": ["user", "rivals", "beat_ai", "best_rival_total"],
      "properties": {
        "user": {"$ref": "#/$defs/UserPoints"},
        "rivals": {"type": "array", "items": {"$ref": "#/$defs/RivalPoints"}},
        "beat_ai": {"type": "boolean"},
        "best_rival_total": {"type": "integer", "minimum": 0, "maximum": 4}
      }
    },
    "PickView": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "status", "record", "result", "scoring"],
      "properties": {
        "schema_version": {"const": "0.1.0"},
        "status": {"enum": ["draft", "locked", "scored", "void"]},
        "record": {"$ref": "#/$defs/UserPick"},
        "result": {"oneOf": [{"$ref": "#/$defs/Result"}, {"type": "null"}]},
        "scoring": {"oneOf": [{"$ref": "#/$defs/PickScoring"}, {"type": "null"}]}
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "scored"}}},
          "then": {
            "properties": {
              "result": {"$ref": "#/$defs/Result"},
              "scoring": {"$ref": "#/$defs/PickScoring"}
            }
          }
        },
        {
          "if": {"properties": {"status": {"enum": ["draft", "locked", "void"]}}},
          "then": {
            "properties": {
              "result": {"type": "null"},
              "scoring": {"type": "null"}
            }
          }
        }
      ]
    },
    "PicksListResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "items", "total", "limit", "offset"],
      "properties": {
        "schema_version": {"const": "0.1.0"},
        "items": {"type": "array", "items": {"$ref": "#/$defs/PickView"}},
        "total": {"type": "integer", "minimum": 0},
        "limit": {"type": "integer", "minimum": 1},
        "offset": {"type": "integer", "minimum": 0}
      }
    },
    "PicksSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "season", "counts", "user", "rivals", "series", "accuracy", "streak", "goal_diff_mae"],
      "properties": {
        "schema_version": {"const": "0.1.0"},
        "season": {"type": ["string", "null"], "pattern": "^[0-9]{4}-[0-9]{2}$"},
        "counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["draft", "locked", "scored", "void"],
          "properties": {
            "draft": {"type": "integer", "minimum": 0},
            "locked": {"type": "integer", "minimum": 0},
            "scored": {"type": "integer", "minimum": 0},
            "void": {"type": "integer", "minimum": 0}
          }
        },
        "user": {
          "type": "object",
          "additionalProperties": false,
          "required": ["total", "exact", "outcome", "bonus"],
          "properties": {
            "total": {"type": "integer", "minimum": 0},
            "exact": {"type": "integer", "minimum": 0},
            "outcome": {"type": "integer", "minimum": 0},
            "bonus": {"type": "integer", "minimum": 0}
          }
        },
        "rivals": {"type": "array", "items": {"$ref": "#/$defs/RivalSeason"}},
        "series": {"type": "array", "items": {"$ref": "#/$defs/SeriesPoint"}},
        "accuracy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["exact", "winner"],
          "properties": {
            "exact": {"type": "number", "minimum": 0, "maximum": 1},
            "winner": {"type": "number", "minimum": 0, "maximum": 1}
          }
        },
        "streak": {
          "type": "object",
          "additionalProperties": false,
          "required": ["current", "best"],
          "properties": {
            "current": {"type": "integer", "minimum": 0},
            "best": {"type": "integer", "minimum": 0}
          }
        },
        "goal_diff_mae": {"type": "number", "minimum": 0}
      }
    },
    "RivalSeason": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "total", "exact", "outcome"],
      "properties": {
        "family": {"type": "string"},
        "total": {"type": "integer", "minimum": 0},
        "exact": {"type": "integer", "minimum": 0},
        "outcome": {"type": "integer", "minimum": 0}
      }
    },
    "SeriesPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kickoff_utc", "match_id", "user_total", "per_family_totals"],
      "properties": {
        "kickoff_utc": {"type": "string", "format": "date-time"},
        "match_id": {"type": "string"},
        "user_total": {"type": "integer", "minimum": 0},
        "per_family_totals": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0}
        }
      }
    }
  }
}
