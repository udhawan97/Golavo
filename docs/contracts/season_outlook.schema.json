{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://golavo.local/contracts/season_outlook.schema.json",
  "title": "Golavo domestic season outlook",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "label",
    "competition_id",
    "competition_name",
    "season",
    "as_of_utc",
    "simulation_rule",
    "ledger_status",
    "reason_code",
    "reason",
    "standings_rule_id",
    "fixture_certificate",
    "current_table",
    "iterations",
    "seed",
    "voices",
    "remaining_fixtures",
    "scenario",
    "provenance"
  ],
  "properties": {
    "schema_version": { "const": "0.2.0" },
    "status": { "enum": ["blocked", "complete", "available"] },
    "label": { "type": "string", "minLength": 1 },
    "competition_id": { "type": "string", "minLength": 1 },
    "competition_name": { "type": "string", "minLength": 1 },
    "season": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
    "as_of_utc": { "type": "string", "format": "date-time" },
    "simulation_rule": { "const": "season-mc-2026.07.1" },
    "ledger_status": { "const": "never_persisted_or_scored_as_a_seal" },
    "reason_code": { "type": ["string", "null"] },
    "reason": { "type": ["string", "null"] },
    "standings_rule_id": { "type": "string", "minLength": 1 },
    "fixture_certificate": { "$ref": "#/$defs/fixtureCertificate" },
    "current_table": {
      "type": "array",
      "items": { "$ref": "#/$defs/standingRow" }
    },
    "iterations": { "type": "integer", "minimum": 0 },
    "seed": { "type": ["integer", "null"], "minimum": 0 },
    "voices": {
      "type": "array",
      "items": { "$ref": "#/$defs/voice" }
    },
    "remaining_fixtures": {
      "type": "array",
      "items": { "$ref": "#/$defs/remainingFixture" }
    },
    "scenario": {
      "oneOf": [{ "$ref": "#/$defs/scenario" }, { "type": "null" }]
    },
    "provenance": { "$ref": "#/$defs/provenance" }
  },
  "$defs": {
    "remainingFixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["match_id", "kickoff_utc", "home_team", "away_team"],
      "properties": {
        "match_id": { "type": "string", "minLength": 1 },
        "kickoff_utc": { "type": "string", "format": "date-time" },
        "home_team": { "type": "string", "minLength": 1 },
        "away_team": { "type": "string", "minLength": 1 }
      }
    },
    "scenarioResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["match_id", "home_team", "away_team", "home_score", "away_score"],
      "properties": {
        "match_id": { "type": "string", "minLength": 1 },
        "home_team": { "type": "string", "minLength": 1 },
        "away_team": { "type": "string", "minLength": 1 },
        "home_score": { "type": "integer", "minimum": 0, "maximum": 20 },
        "away_score": { "type": "integer", "minimum": 0, "maximum": 20 }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hypothetical_only", "persisted", "model_input", "forced_results"],
      "properties": {
        "hypothetical_only": { "const": true },
        "persisted": { "const": false },
        "model_input": { "const": false },
        "forced_results": {
          "type": "array",
          "minItems": 1,
          "maxItems": 12,
          "items": { "$ref": "#/$defs/scenarioResult" }
        }
      }
    },
    "fixtureCertificate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expected_teams",
        "observed_teams",
        "teams",
        "expected_matches",
        "observed_matches",
        "unique_ordered_pairs",
        "duplicate_ordered_pairs",
        "self_fixtures",
        "incomplete_fixtures",
        "past_result_gaps",
        "future_completed_results",
        "complete_fixture_list"
      ],
      "properties": {
        "expected_teams": { "type": "integer", "minimum": 2 },
        "observed_teams": { "type": "integer", "minimum": 0 },
        "teams": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "expected_matches": { "type": "integer", "minimum": 2 },
        "observed_matches": { "type": "integer", "minimum": 0 },
        "unique_ordered_pairs": { "type": "integer", "minimum": 0 },
        "duplicate_ordered_pairs": { "type": "integer", "minimum": 0 },
        "self_fixtures": { "type": "integer", "minimum": 0 },
        "incomplete_fixtures": { "type": "integer", "minimum": 0 },
        "past_result_gaps": { "type": "integer", "minimum": 0 },
        "future_completed_results": { "type": "integer", "minimum": 0 },
        "complete_fixture_list": { "type": "boolean" }
      }
    },
    "standingRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "position",
        "team",
        "played",
        "won",
        "drawn",
        "lost",
        "goals_for",
        "goals_against",
        "goal_difference",
        "points_adjustment",
        "points"
      ],
      "properties": {
        "position": { "type": "integer", "minimum": 1 },
        "team": { "type": "string", "minLength": 1 },
        "played": { "type": "integer", "minimum": 0 },
        "won": { "type": "integer", "minimum": 0 },
        "drawn": { "type": "integer", "minimum": 0 },
        "lost": { "type": "integer", "minimum": 0 },
        "goals_for": { "type": "integer", "minimum": 0 },
        "goals_against": { "type": "integer", "minimum": 0 },
        "goal_difference": { "type": "integer" },
        "points_adjustment": { "type": "integer" },
        "points": { "type": "integer" }
      }
    },
    "displayPercent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "top_four", "relegation"],
      "properties": {
        "title": { "type": "number", "minimum": 0, "maximum": 100 },
        "top_four": { "type": "number", "minimum": 0, "maximum": 100 },
        "relegation": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "teamProbability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["team", "title", "top_four", "relegation", "display_percent"],
      "properties": {
        "team": { "type": "string", "minLength": 1 },
        "title": { "type": "number", "minimum": 0, "maximum": 1 },
        "top_four": { "type": "number", "minimum": 0, "maximum": 1 },
        "relegation": { "type": "number", "minimum": 0, "maximum": 1 },
        "display_percent": { "$ref": "#/$defs/displayPercent" }
      }
    },
    "totals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "top_four", "relegation"],
      "properties": {
        "title": { "type": "number", "minimum": 0 },
        "top_four": { "type": "number", "minimum": 0 },
        "relegation": { "type": "number", "minimum": 0 }
      }
    },
    "voice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["voice_id", "label", "role", "scoreline_method", "teams", "totals"],
      "properties": {
        "voice_id": {
          "enum": ["elo_ordlogit", "dixon_coles", "equal-chance-baseline"]
        },
        "label": { "type": "string", "minLength": 1 },
        "role": { "enum": ["voice", "baseline"] },
        "scoreline_method": { "type": "string", "minLength": 1 },
        "teams": { "type": "array", "items": { "$ref": "#/$defs/teamProbability" } },
        "totals": { "$ref": "#/$defs/totals" }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_ids", "index_sha256"],
      "properties": {
        "source_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "training_source_ids": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "training_data_through_utc": { "type": "string", "format": "date-time" },
        "index_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    }
  }
}
