{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://udhawan97.github.io/Golavo/contracts/forecast-artifact-0.2.0.schema.json",
  "title": "ForecastArtifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_id", "status", "match", "forecast", "model", "inputs", "provenance", "evaluation"],
  "properties": {
    "schema_version": {"enum": ["0.1.0", "0.2.0"]},
    "artifact_id": {"type": "string", "pattern": "^fa_[a-z0-9]{8,}$"},
    "status": {"enum": ["sealed", "scored", "abstained", "voided"]},
    "supersedes": {"type": ["string", "null"], "pattern": "^fa_[a-z0-9]{8,}$"},
    "void_reason": {"type": ["string", "null"], "minLength": 1},
    "match": {"$ref": "#/$defs/Match"},
    "forecast": {"$ref": "#/$defs/Forecast"},
    "model": {"$ref": "#/$defs/Model"},
    "inputs": {"$ref": "#/$defs/Inputs"},
    "provenance": {"$ref": "#/$defs/Provenance"},
    "evaluation": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/Evaluation"}
      ]
    }
  },
  "$defs": {
    "Match": {
      "type": "object",
      "additionalProperties": false,
      "required": ["match_id", "competition", "kickoff_utc", "home_team", "away_team", "neutral_venue"],
      "properties": {
        "match_id": {"type": "string", "minLength": 1},
        "competition": {"type": "string", "minLength": 1},
        "stage": {"type": ["string", "null"]},
        "kickoff_utc": {"type": "string", "format": "date-time"},
        "home_team": {"type": "string", "minLength": 1},
        "away_team": {"type": "string", "minLength": 1},
        "neutral_venue": {"type": "boolean"},
        "city": {"type": ["string", "null"]},
        "country": {"type": ["string", "null"]}
      }
    },
    "Probabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["home", "draw", "away"],
      "properties": {
        "home": {"type": "number", "minimum": 0, "maximum": 1},
        "draw": {"type": "number", "minimum": 0, "maximum": 1},
        "away": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "ExpectedGoals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["home", "away"],
      "properties": {
        "home": {"type": "number", "minimum": 0},
        "away": {"type": "number", "minimum": 0}
      }
    },
    "Forecast": {
      "type": "object",
      "additionalProperties": false,
      "required": ["market", "sealed_at_utc", "horizon", "probs", "expected_goals", "abstained", "abstain_reason", "uncertainty"],
      "properties": {
        "market": {"const": "1x2_regulation"},
        "sealed_at_utc": {"type": "string", "format": "date-time"},
        "horizon": {"enum": ["T-72h", "T-24h", "T-60m"]},
        "probs": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/Probabilities"}]},
        "expected_goals": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/ExpectedGoals"}]},
        "abstained": {"type": "boolean"},
        "abstain_reason": {"type": ["string", "null"]},
        "uncertainty": {"enum": ["low", "medium", "high"]},
        "score_matrix": {"$ref": "#/$defs/ScoreMatrix"}
      }
    },
    "ScoreMatrix": {
      "type": "object",
      "description": "Additive (schema 0.2.0). The exact-score distribution the sealed 1X2 forecast already implies, for goal-based families only. grid[i][j] is P(home=i, away=j) for 0..max_goals per side; everything beyond folds into the outcome-decomposed tail. grid + tail is an exact partition of the distribution, so its win/draw/loss marginals reproduce forecast.probs (enforced on load).",
      "additionalProperties": false,
      "required": ["max_goals", "resolution", "grid", "tail", "most_likely", "total_probability"],
      "properties": {
        "max_goals": {"type": "integer", "minimum": 1},
        "resolution": {"type": "integer", "minimum": 1},
        "grid": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "number", "minimum": 0, "maximum": 1}
          }
        },
        "tail": {
          "type": "object",
          "additionalProperties": false,
          "required": ["probability", "home", "draw", "away"],
          "properties": {
            "probability": {"type": "number", "minimum": 0, "maximum": 1},
            "home": {"type": "number", "minimum": 0, "maximum": 1},
            "draw": {"type": "number", "minimum": 0, "maximum": 1},
            "away": {"type": "number", "minimum": 0, "maximum": 1}
          }
        },
        "most_likely": {
          "type": "object",
          "additionalProperties": false,
          "required": ["home", "away", "probability"],
          "properties": {
            "home": {"type": "integer", "minimum": 0},
            "away": {"type": "integer", "minimum": 0},
            "probability": {"type": "number", "minimum": 0, "maximum": 1}
          }
        },
        "total_probability": {"type": "number", "minimum": 0}
      }
    },
    "Model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_id", "family", "version", "params_hash", "code_git_sha", "seed"],
      "properties": {
        "model_id": {"type": "string", "minLength": 1},
        "family": {"enum": ["climatological", "elo_ordlogit", "poisson_independent", "dixon_coles", "bivariate_poisson"]},
        "version": {"type": "string", "minLength": 1},
        "params_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "code_git_sha": {"type": "string", "pattern": "^[a-f0-9]{7,40}$"},
        "seed": {"type": "integer"}
      }
    },
    "Snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["snapshot_id", "source_id", "url", "upstream_ref", "retrieved_at_utc", "sha256", "license"],
      "properties": {
        "snapshot_id": {"type": "string", "minLength": 1},
        "source_id": {"type": "string", "minLength": 1},
        "url": {"type": "string", "format": "uri"},
        "upstream_ref": {"type": "string", "minLength": 1},
        "retrieved_at_utc": {"type": "string", "format": "date-time"},
        "upstream_committed_at_utc": {"type": ["string", "null"], "format": "date-time"},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "license": {"type": "string", "minLength": 1}
      }
    },
    "Inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["training_cutoff_utc", "snapshots"],
      "properties": {
        "training_cutoff_utc": {"type": "string", "format": "date-time"},
        "snapshots": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/Snapshot"}}
      }
    },
    "Provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_at_utc", "generator", "deterministic", "payload_sha256"],
      "properties": {
        "created_at_utc": {"type": "string", "format": "date-time"},
        "generator": {"type": "string", "minLength": 1},
        "deterministic": {"const": true},
        "payload_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "ActualResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["home_goals", "away_goals", "outcome"],
      "properties": {
        "home_goals": {"type": "integer", "minimum": 0},
        "away_goals": {"type": "integer", "minimum": 0},
        "outcome": {"enum": ["home", "draw", "away"]}
      }
    },
    "ScoreMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["log_loss", "brier", "prob_assigned_to_outcome"],
      "properties": {
        "log_loss": {"type": "number", "minimum": 0},
        "brier": {"type": "number", "minimum": 0},
        "prob_assigned_to_outcome": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "Evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actual", "scored_at_utc", "metrics"],
      "properties": {
        "actual": {"$ref": "#/$defs/ActualResult"},
        "scored_at_utc": {"type": "string", "format": "date-time"},
        "metrics": {"$ref": "#/$defs/ScoreMetrics"}
      }
    },
    "EvalSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "generated_at_utc", "primary_metric", "source_snapshot", "folds"],
      "properties": {
        "schema_version": {"const": "0.1.0"},
        "generated_at_utc": {"type": "string", "format": "date-time"},
        "primary_metric": {"const": "log_loss"},
        "source_snapshot": {"$ref": "#/$defs/Snapshot"},
        "report_cards": {
          "type": "array",
          "items": {"$ref": "#/$defs/ReportCard"}
        },
        "folds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["fold_id", "competition", "window_start", "window_end", "training_cutoff_utc", "n_matches", "models"],
            "properties": {
              "fold_id": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9-]*$"},
              "competition": {"type": "string"},
              "window_start": {"type": "string", "format": "date"},
              "window_end": {"type": "string", "format": "date"},
              "training_cutoff_utc": {"type": "string", "format": "date-time"},
              "n_matches": {"type": "integer", "minimum": 1},
              "models": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["family", "params", "log_loss", "brier", "ece", "rps", "reliability_bins"],
                  "properties": {
                    "family": {"enum": ["climatological", "elo_ordlogit", "poisson_independent", "dixon_coles", "bivariate_poisson"]},
                    "params": {"type": "object"},
                    "log_loss": {"type": "number", "minimum": 0},
                    "brier": {"type": "number", "minimum": 0},
                    "ece": {"type": "number", "minimum": 0},
                    "rps": {"type": "number", "minimum": 0},
                    "reliability_bins": {"type": "array", "items": {"$ref": "#/$defs/ReliabilityBin"}}
                  }
                }
              }
            }
          }
        }
      }
    },
    "ReportCard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["competition", "baseline_family", "primary_metric", "minimum_matches", "bootstrap", "window_start", "window_end", "models"],
      "properties": {
        "competition": {"type": "string"},
        "baseline_family": {"const": "climatological"},
        "primary_metric": {"const": "log_loss"},
        "minimum_matches": {"type": "integer", "minimum": 1},
        "bootstrap": {
          "type": "object",
          "additionalProperties": false,
          "required": ["method", "replicates", "seed"],
          "properties": {
            "method": {"const": "fold-stratified-match-bootstrap"},
            "replicates": {"type": "integer", "minimum": 1},
            "seed": {"type": "integer"}
          }
        },
        "window_start": {"type": "string", "format": "date"},
        "window_end": {"type": "string", "format": "date"},
        "models": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/ReportCardModel"}
        }
      }
    },
    "ReportCardModel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "n_matches", "n_folds", "log_loss", "brier", "ece", "rps", "skill_score", "skill_ci_95", "sample_status", "mean_rank", "best_rank", "worst_rank", "first_place_folds"],
      "properties": {
        "family": {"enum": ["climatological", "elo_ordlogit", "poisson_independent", "dixon_coles", "bivariate_poisson"]},
        "n_matches": {"type": "integer", "minimum": 1},
        "n_folds": {"type": "integer", "minimum": 1},
        "log_loss": {"type": "number", "minimum": 0},
        "brier": {"type": "number", "minimum": 0},
        "ece": {"type": "number", "minimum": 0},
        "rps": {"type": "number", "minimum": 0},
        "skill_score": {"type": "number"},
        "skill_ci_95": {
          "oneOf": [
            {"type": "null"},
            {
              "type": "array",
              "prefixItems": [{"type": "number"}, {"type": "number"}],
              "minItems": 2,
              "maxItems": 2
            }
          ]
        },
        "sample_status": {"enum": ["available", "insufficient_sample"]},
        "mean_rank": {"type": "number", "minimum": 1},
        "best_rank": {"type": "integer", "minimum": 1},
        "worst_rank": {"type": "integer", "minimum": 1},
        "first_place_folds": {"type": "integer", "minimum": 0}
      }
    },
    "ReliabilityBin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lower", "upper", "count", "mean_confidence", "accuracy", "wilson_low", "wilson_high"],
      "properties": {
        "lower": {"type": "number"},
        "upper": {"type": "number"},
        "count": {"type": "integer", "minimum": 0},
        "mean_confidence": {"type": ["number", "null"]},
        "accuracy": {"type": ["number", "null"]},
        "wilson_low": {"type": ["number", "null"]},
        "wilson_high": {"type": ["number", "null"]}
      }
    },
    "CalibrationChain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sealed_artifact_id", "match", "sealed_at_utc", "horizon", "family", "abstained", "probs", "resolution"],
      "properties": {
        "sealed_artifact_id": {"type": "string", "pattern": "^fa_[a-z0-9]{8,}$"},
        "match": {"$ref": "#/$defs/Match"},
        "sealed_at_utc": {"type": "string", "format": "date-time"},
        "horizon": {"enum": ["T-72h", "T-24h", "T-60m"]},
        "family": {"enum": ["climatological", "elo_ordlogit", "poisson_independent", "dixon_coles", "bivariate_poisson"]},
        "abstained": {"type": "boolean"},
        "probs": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/Probabilities"}]},
        "resolution": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "artifact_id", "resolved_at_utc", "actual", "metrics", "void_reason"],
          "properties": {
            "status": {"enum": ["pending", "scored", "voided"]},
            "artifact_id": {"type": ["string", "null"], "pattern": "^fa_[a-z0-9]{8,}$"},
            "resolved_at_utc": {"type": ["string", "null"], "format": "date-time"},
            "actual": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/ActualResult"}]},
            "metrics": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/ScoreMetrics"}]},
            "void_reason": {"type": ["string", "null"]}
          }
        }
      }
    },
    "CalibrationSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "generated_from", "primary_metric", "counts", "running", "reliability_bins", "chains"],
      "properties": {
        "schema_version": {"const": "0.2.0"},
        "generated_from": {"type": "string", "minLength": 1},
        "primary_metric": {"const": "log_loss"},
        "counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sealed", "abstained", "scored", "voided", "pending"],
          "properties": {
            "sealed": {"type": "integer", "minimum": 0},
            "abstained": {"type": "integer", "minimum": 0},
            "scored": {"type": "integer", "minimum": 0},
            "voided": {"type": "integer", "minimum": 0},
            "pending": {"type": "integer", "minimum": 0}
          }
        },
        "running": {
          "oneOf": [
            {"type": "null"},
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["n_scored", "log_loss", "brier", "prob_assigned_to_outcome"],
              "properties": {
                "n_scored": {"type": "integer", "minimum": 1},
                "log_loss": {"type": "number", "minimum": 0},
                "brier": {"type": "number", "minimum": 0},
                "prob_assigned_to_outcome": {"type": "number", "minimum": 0, "maximum": 1}
              }
            }
          ]
        },
        "reliability_bins": {"type": "array", "items": {"$ref": "#/$defs/ReliabilityBin"}},
        "chains": {"type": "array", "items": {"$ref": "#/$defs/CalibrationChain"}}
      }
    }
  }
}
