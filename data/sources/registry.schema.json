{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://golavo.dev/schemas/source_registry.schema.json",
  "title": "Golavo source registry",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "license_classes", "sources"],
  "properties": {
    "schema_version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "license_classes": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/source"}
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "source_id",
        "name",
        "contributors",
        "url",
        "license",
        "classification",
        "verified",
        "notes"
      ],
      "properties": {
        "source_id": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1},
        "contributors": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "url": {"type": "string", "format": "uri"},
        "license": {"type": "string", "minLength": 1},
        "license_url": {"type": ["string", "null"]},
        "classification": {
          "type": "string",
          "enum": [
            "core",
            "enrichment",
            "odbl-pack",
            "by-sa-pack",
            "research-pack",
            "per-user-context",
            "dev-only",
            "rejected",
            "blocked"
          ]
        },
        "pin_strategy": {"type": "string"},
        "pin": {"type": "string"},
        "citation_key": {"type": "string"},
        "fields": {"type": "string"},
        "attribution": {"type": "string"},
        "share_alike": {"type": "boolean"},
        "refresh": {"$ref": "#/$defs/refresh"},
        "overlay": {"$ref": "#/$defs/overlay"},
        "entity_access": {"$ref": "#/$defs/entityAccess"},
        "research_access": {"$ref": "#/$defs/researchAccess"},
        "corrections": {"$ref": "#/$defs/correctionPolicy"},
        "recheck_by": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
        "verified": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
        "notes": {"type": "string"}
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "classification": {
                "enum": ["core", "enrichment", "odbl-pack", "by-sa-pack", "research-pack"]
              }
            }
          },
          "then": {"required": ["attribution"]}
        },
        {
          "if": {
            "properties": {"classification": {"enum": ["blocked", "rejected"]}}
          },
          "then": {
            "properties": {"license": {"type": "string"}}
          }
        }
      ]
    },
    "refresh": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "supported",
        "adapter",
        "repository",
        "branch",
        "allowed_paths",
        "default_interval_seconds",
        "max_file_bytes",
        "max_snapshot_bytes"
      ],
      "properties": {
        "supported": {"const": true},
        "adapter": {
          "type": "string",
          "enum": ["martj42-international-results", "openfootball-worldcup-json", "openfootball-football-json", "openfootball-england", "openfootball-deutschland", "openfootball-espana", "openfootball-italy", "openfootball-europe"]
        },
        "repository": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
        "branch": {"type": "string", "minLength": 1},
        "allowed_paths": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "default_interval_seconds": {"type": "integer", "minimum": 900},
        "max_file_bytes": {"type": "integer", "minimum": 1024},
        "max_snapshot_bytes": {"type": "integer", "minimum": 1024}
      }
    },
    "correctionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled", "license_namespace", "allowed_types", "evidence_hosts",
        "local_annotation", "redistributable_export", "contribution_url"
      ],
      "properties": {
        "enabled": {"const": true},
        "license_namespace": {
          "enum": [
            "core-cc0", "enrichment-cc0", "enrichment-public-domain",
            "enrichment-cc-by-4.0", "research-cc-by-sa-4.0", "overlay-odbl-1.0"
          ]
        },
        "allowed_types": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["missing_fixture", "kickoff_time", "team_alias", "venue", "final_score"]
          }
        },
        "evidence_hosts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[A-Za-z0-9.-]+$"}
        },
        "local_annotation": {"const": true},
        "redistributable_export": {"type": "boolean"},
        "contribution_url": {"type": "string", "format": "uri"}
      }
    },
    "entityAccess": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode", "runtime_network", "allowed_namespaces", "allowed_properties",
        "languages", "max_entities", "retain_revision_evidence"
      ],
      "properties": {
        "mode": {"const": "revision-pinned-individual-entities"},
        "runtime_network": {"const": false},
        "allowed_namespaces": {"const": ["item", "property"]},
        "allowed_properties": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "pattern": "^P[1-9][0-9]*$"},
          "uniqueItems": true
        },
        "languages": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "pattern": "^[a-z]{2,3}$"},
          "uniqueItems": true
        },
        "max_entities": {"type": "integer", "minimum": 1, "maximum": 300},
        "retain_revision_evidence": {"const": true}
      }
    },
    "researchAccess": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled", "roles", "hosts", "schemes", "ports", "methods",
        "path_patterns", "redirect_hosts", "content_types", "max_raw_bytes",
        "license_namespace", "permitted_fact_types", "parser_id", "parser_version",
        "ai_fallback", "attribution_required", "terms_url", "terms_verified_at",
        "recheck_by"
      ],
      "properties": {
        "enabled": {"const": true},
        "roles": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"enum": ["discovery", "capture", "structured"]}
        },
        "hosts": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[A-Za-z0-9.-]+$"}
        },
        "schemes": {"const": ["https"]},
        "ports": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"type": "integer", "minimum": 1, "maximum": 65535}
        },
        "methods": {"const": ["GET"]},
        "path_patterns": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "redirect_hosts": {
          "type": "array", "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[A-Za-z0-9.-]+$"}
        },
        "allowed_query_keys": {
          "type": "array", "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[A-Za-z0-9_]+$"}
        },
        "content_types": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"enum": ["application/json", "text/plain", "text/html", "text/csv"]}
        },
        "max_raw_bytes": {"type": "integer", "minimum": 1024, "maximum": 2097152},
        "license_namespace": {
          "enum": [
            "core-cc0", "enrichment-cc0", "enrichment-public-domain",
            "enrichment-cc-by-4.0", "research-cc-by-sa-4.0"
          ]
        },
        "permitted_fact_types": {
          "type": "array", "uniqueItems": true,
          "items": {"enum": ["missing_fixture", "kickoff_time", "team_alias", "venue", "final_score"]}
        },
        "parser_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$"},
        "parser_version": {"type": "string", "minLength": 1},
        "ai_fallback": {"type": "boolean"},
        "attribution_required": {"type": "boolean"},
        "terms_url": {"type": "string", "format": "uri"},
        "terms_verified_at": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
        "recheck_by": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"}
      }
    },
    "overlay": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adapter",
        "bundled_data",
        "fetch_per_user",
        "display_only",
        "host",
        "methods",
        "path_templates",
        "competition_shortcuts",
        "default_interval_seconds",
        "max_response_bytes",
        "storage_boundary"
      ],
      "properties": {
        "adapter": {"const": "openligadb-v1"},
        "bundled_data": {"const": false},
        "fetch_per_user": {"const": true},
        "display_only": {"const": true},
        "host": {"const": "api.openligadb.de"},
        "methods": {"const": ["GET"]},
        "path_templates": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "competition_shortcuts": {
          "type": "array",
          "minItems": 1,
          "items": {"enum": ["bl1", "bl2", "bl3", "dfb"]},
          "uniqueItems": true
        },
        "default_interval_seconds": {"type": "integer", "minimum": 21600},
        "max_response_bytes": {"type": "integer", "minimum": 1024, "maximum": 16777216},
        "storage_boundary": {"const": "overlays/openligadb"}
      }
    }
  }
}
