{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://golavo.dev/schemas/source_registry.schema.json",
  "title": "Golavo source registry",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "license_classes", "sources"],
  "properties": {
    "schema_version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "license_classes": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/source"}
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "source_id",
        "name",
        "contributors",
        "url",
        "license",
        "classification",
        "verified",
        "notes"
      ],
      "properties": {
        "source_id": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1},
        "contributors": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "url": {"type": "string", "format": "uri"},
        "license": {"type": "string", "minLength": 1},
        "license_url": {"type": ["string", "null"]},
        "classification": {
          "type": "string",
          "enum": [
            "core",
            "enrichment",
            "odbl-pack",
            "by-sa-pack",
            "research-pack",
            "dev-only",
            "rejected",
            "blocked"
          ]
        },
        "pin_strategy": {"type": "string"},
        "pin": {"type": "string"},
        "citation_key": {"type": "string"},
        "fields": {"type": "string"},
        "attribution": {"type": "string"},
        "share_alike": {"type": "boolean"},
        "refresh": {"$ref": "#/$defs/refresh"},
        "overlay": {"$ref": "#/$defs/overlay"},
        "recheck_by": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
        "verified": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
        "notes": {"type": "string"}
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "classification": {
                "enum": ["core", "enrichment", "odbl-pack", "by-sa-pack", "research-pack"]
              }
            }
          },
          "then": {"required": ["attribution"]}
        },
        {
          "if": {
            "properties": {"classification": {"enum": ["blocked", "rejected"]}}
          },
          "then": {
            "properties": {"license": {"type": "string"}}
          }
        }
      ]
    },
    "refresh": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "supported",
        "adapter",
        "repository",
        "branch",
        "allowed_paths",
        "default_interval_seconds",
        "max_file_bytes",
        "max_snapshot_bytes"
      ],
      "properties": {
        "supported": {"const": true},
        "adapter": {
          "type": "string",
          "enum": ["martj42-international-results", "openfootball-worldcup-json", "openfootball-football-json"]
        },
        "repository": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
        "branch": {"type": "string", "minLength": 1},
        "allowed_paths": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "default_interval_seconds": {"type": "integer", "minimum": 900},
        "max_file_bytes": {"type": "integer", "minimum": 1024},
        "max_snapshot_bytes": {"type": "integer", "minimum": 1024}
      }
    },
    "overlay": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adapter",
        "bundled_data",
        "fetch_per_user",
        "display_only",
        "host",
        "methods",
        "path_templates",
        "competition_shortcuts",
        "default_interval_seconds",
        "max_response_bytes",
        "storage_boundary"
      ],
      "properties": {
        "adapter": {"const": "openligadb-v1"},
        "bundled_data": {"const": false},
        "fetch_per_user": {"const": true},
        "display_only": {"const": true},
        "host": {"const": "api.openligadb.de"},
        "methods": {"const": ["GET"]},
        "path_templates": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "competition_shortcuts": {
          "type": "array",
          "minItems": 1,
          "items": {"enum": ["bl1", "bl2", "bl3", "dfb"]},
          "uniqueItems": true
        },
        "default_interval_seconds": {"type": "integer", "minimum": 21600},
        "max_response_bytes": {"type": "integer", "minimum": 1024, "maximum": 16777216},
        "storage_boundary": {"const": "overlays/openligadb"}
      }
    }
  }
}
