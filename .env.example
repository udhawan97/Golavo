# Golavo local configuration.
# Copy to `.env` for source-mode development. NEVER commit a real .env.
# Every key here is OPTIONAL — Golavo runs fully local with none of them.
# In the packaged desktop app, secrets live in the OS keychain, not in .env.

# --- Local server ---
GOLAVO_HOST=127.0.0.1
GOLAVO_PORT=0                 # 0 = OS-assigned ephemeral port
# GOLAVO_LAUNCH_TOKEN is generated per launch by the desktop shell; do not set it here.

# --- CORS (the desktop shell sets this automatically) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,tauri://localhost

# --- Optional BYOK data adapters (dev only; the app uses the OS keychain) ---
# These feed TYPED FEATURES into the statistical engine. They never redistribute raw data.
# FOOTBALL_DATA_ORG_KEY=
# API_FOOTBALL_KEY=

# --- Optional AI (Bring Your Own Key). Local models need no key. ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# Local OpenAI-compatible endpoints (defaults shown):
# OLLAMA_BASE_URL=http://localhost:11434/v1
# LLAMACPP_BASE_URL=http://127.0.0.1:8080/v1

# --- AI spend caps (USD) ---
AI_PER_MATCH_CAP=0.05
AI_MONTHLY_CAP=5.00
