---
/**
 * Golavo — bespoke search (overrides Starlight's default Search).
 *
 * Design: a single, quiet magnifier button lives in the header. Tap it (or ⌘K)
 * and it springs open into an inline search pill that grows leftward from the
 * button, with a floating results drawer beneath. Tap away or press Esc and it
 * collapses back to the button. Real search is still powered by Pagefind — we
 * simply mount its UI inside our expanding pill instead of a full-screen modal.
 *
 * Motion is spring-eased and honors prefers-reduced-motion.
 */
const label = Astro.locals.t?.("search.label") ?? "Search";
---

<golavo-search class="gv-search">
  <!-- Collapsed affordance: a calm circular magnifier. -->
  <button
    type="button"
    class="gv-search__toggle"
    aria-label={label}
    aria-expanded="false"
    aria-controls="gv-search-field"
    aria-keyshortcuts="Meta+K"
  >
    <svg class="gv-search__glyph" viewBox="0 0 24 24" width="19" height="19" fill="none" aria-hidden="true">
      <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2" />
      <path d="m20 20-3.6-3.6" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
    </svg>
    <kbd class="gv-search__kbd" aria-hidden="true"><kbd data-mod>⌘</kbd><kbd>K</kbd></kbd>
  </button>

  <!-- Expanded state: the pill + Pagefind mount + floating results drawer. -->
  <div class="gv-search__field" id="gv-search-field" role="search">
    <svg class="gv-search__glyph gv-search__glyph--lead" viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
      <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2" />
      <path d="m20 20-3.6-3.6" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
    </svg>
    <div class="gv-search__mount" id="starlight__search"></div>
    <button type="button" class="gv-search__close" aria-label="Close search" tabindex="-1">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" aria-hidden="true">
        <path d="M6 6l12 12M18 6 6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
    </button>
  </div>
</golavo-search>

<script>
  class GolavoSearch extends HTMLElement {
    connectedCallback() {
      const root = this;
      const toggle = root.querySelector<HTMLButtonElement>(".gv-search__toggle")!;
      const field = root.querySelector<HTMLDivElement>(".gv-search__field")!;
      const closeBtn = root.querySelector<HTMLButtonElement>(".gv-search__close")!;
      const mount = root.querySelector<HTMLDivElement>("#starlight__search")!;
      let mounted = false;

      const inputEl = () => root.querySelector<HTMLInputElement>("input");

      const open = () => {
        if (root.classList.contains("is-open")) return;
        root.classList.add("is-open");
        toggle.setAttribute("aria-expanded", "true");
        ensurePagefind();
        // Focus once the pill has room; input may be created async by Pagefind.
        requestAnimationFrame(() => inputEl()?.focus());
        setTimeout(() => inputEl()?.focus(), 60);
      };

      const close = () => {
        if (!root.classList.contains("is-open")) return;
        root.classList.remove("is-open");
        toggle.setAttribute("aria-expanded", "false");
        inputEl()?.blur();
      };

      toggle.addEventListener("click", () =>
        root.classList.contains("is-open") ? close() : open(),
      );
      closeBtn.addEventListener("click", () => {
        close();
        toggle.focus();
      });

      // Click outside collapses.
      document.addEventListener("click", (e) => {
        if (root.classList.contains("is-open") && !root.contains(e.target as Node)) close();
      });

      // Esc collapses (and returns focus to the button).
      root.addEventListener("keydown", (e) => {
        if (e.key === "Escape") {
          close();
          toggle.focus();
        }
      });

      // ⌘K / Ctrl+K toggles from anywhere.
      window.addEventListener("keydown", (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
          e.preventDefault();
          root.classList.contains("is-open") ? close() : open();
        }
      });

      // Platform-correct shortcut hint.
      const mod = root.querySelector<HTMLElement>("kbd[data-mod]");
      if (mod && !/Mac|iPhone|iPod|iPad/i.test(navigator.platform)) {
        mod.textContent = "Ctrl";
        toggle.setAttribute("aria-keyshortcuts", "Control+K");
      }

      async function ensurePagefind() {
        if (mounted) return;
        mounted = true;
        // Pagefind's index is only generated at build time, so in dev we show a
        // real (but inert) field purely to demonstrate the expand animation.
        if (import.meta.env.DEV) {
          mount.innerHTML =
            '<form class="pagefind-ui__form" role="search">' +
            '<input class="pagefind-ui__search-input" placeholder="Search the docs…" aria-label="Search the docs" />' +
            '</form>' +
            '<div class="gv-search__devnote">Live results appear in the built site.</div>';
          return;
        }
        try {
          // @ts-expect-error — no types shipped for @pagefind/default-ui.
          const { PagefindUI } = await import("@pagefind/default-ui");
          new PagefindUI({
            element: mount,
            baseUrl: import.meta.env.BASE_URL,
            bundlePath: import.meta.env.BASE_URL.replace(/\/$/, "") + "/pagefind/",
            showImages: false,
            showSubResults: true,
            resetStyles: false,
            translations: { placeholder: "Search the docs…" },
          });
          requestAnimationFrame(() => inputEl()?.focus());
        } catch {
          mount.innerHTML =
            '<div class="gv-search__devnote">Search is unavailable right now.</div>';
        }
      }
    }
  }
  if (!customElements.get("golavo-search")) {
    customElements.define("golavo-search", GolavoSearch);
  }
</script>

<style is:global>
  @import url("@pagefind/default-ui/css/ui.css") layer(starlight.core);

  @layer starlight.core {
    /* ---------- Shell: hug the right of the header's free column ---------- */
    .gv-search {
      display: flex;
      justify-content: flex-end;
      align-items: center;
      width: 100%;
      position: relative;
      z-index: 20;
    }

    /* ---------- Collapsed: circular magnifier button ---------- */
    .gv-search__toggle {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      height: 2.5rem;
      padding: 0 0.5rem 0 0.7rem;
      border: 1px solid var(--sl-color-hairline-light);
      border-radius: 999px;
      background: color-mix(in srgb, var(--sl-color-bg) 55%, transparent);
      -webkit-backdrop-filter: blur(8px);
      backdrop-filter: blur(8px);
      color: var(--sl-color-gray-2);
      cursor: pointer;
      transition:
        transform 0.45s var(--gv-ease, cubic-bezier(0.16, 0.7, 0.3, 1)),
        border-color 0.25s ease,
        color 0.25s ease,
        background 0.25s ease,
        opacity 0.3s ease;
    }
    .gv-search__toggle:hover {
      color: var(--sl-color-white);
      border-color: color-mix(in srgb, var(--golavo-gold) 55%, var(--sl-color-hairline-light));
      transform: translateY(-1px);
    }
    .gv-search__toggle:focus-visible {
      outline: 2px solid var(--golavo-gold);
      outline-offset: 2px;
    }
    .gv-search__glyph {
      flex: none;
      transition: transform 0.45s var(--gv-ease, cubic-bezier(0.16, 0.7, 0.3, 1));
    }
    .gv-search__toggle:hover .gv-search__glyph {
      transform: rotate(-8deg) scale(1.06);
    }
    /* ⌘K chip — only on wider viewports, where there's room. */
    .gv-search__kbd {
      display: none;
      gap: 0.15em;
      font-family: var(--gv-mono);
      font-size: 0.62rem;
      letter-spacing: 0.02em;
      color: var(--sl-color-gray-3);
    }
    .gv-search__kbd kbd {
      padding: 0.1rem 0.3rem;
      border-radius: 0.3rem;
      background: color-mix(in srgb, var(--sl-color-gray-5) 45%, transparent);
      line-height: 1;
    }
    @media (min-width: 50rem) {
      .gv-search__kbd {
        display: inline-flex;
      }
    }

    /* ---------- Expanded: the inline pill ---------- */
    .gv-search__field {
      position: absolute;
      inset-inline-end: 0;
      top: 50%;
      translate: 0 -50%;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      width: 2.5rem; /* collapsed footprint, hidden behind the toggle */
      max-width: min(24rem, 62vw);
      height: 2.5rem;
      padding: 0 0.35rem 0 0.85rem;
      border: 1px solid transparent;
      border-radius: 999px;
      background: color-mix(in srgb, var(--sl-color-bg) 94%, var(--sl-color-gray-6));
      -webkit-backdrop-filter: blur(14px) saturate(1.3);
      backdrop-filter: blur(14px) saturate(1.3);
      box-shadow: 0 12px 34px -18px rgba(0, 0, 0, 0.7);
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition:
        width 0.5s var(--gv-ease, cubic-bezier(0.16, 0.7, 0.3, 1)),
        opacity 0.32s ease,
        border-color 0.3s ease,
        box-shadow 0.3s ease,
        visibility 0s linear 0.5s;
    }
    .gv-search.is-open .gv-search__field {
      width: min(24rem, 62vw);
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      border-color: color-mix(in srgb, var(--golavo-gold) 42%, var(--sl-color-hairline-light));
      transition:
        width 0.5s var(--gv-ease, cubic-bezier(0.16, 0.7, 0.3, 1)),
        opacity 0.28s ease,
        border-color 0.3s ease,
        box-shadow 0.3s ease,
        visibility 0s;
    }
    .gv-search.is-open .gv-search__field:focus-within {
      border-color: var(--golavo-gold);
      box-shadow:
        0 12px 34px -18px rgba(0, 0, 0, 0.7),
        0 0 0 3px color-mix(in srgb, var(--golavo-gold) 22%, transparent);
    }
    /* Fade the toggle out as the pill takes over its spot. */
    .gv-search.is-open .gv-search__toggle {
      opacity: 0;
      pointer-events: none;
    }

    .gv-search__glyph--lead {
      flex: none;
      color: var(--sl-color-gray-2);
      opacity: 0;
      transition: opacity 0.3s ease 0.12s;
    }
    .gv-search.is-open .gv-search__glyph--lead {
      opacity: 1;
    }

    .gv-search__mount {
      flex: 1 1 auto;
      min-width: 0;
    }

    .gv-search__close {
      flex: none;
      display: grid;
      place-items: center;
      width: 1.8rem;
      height: 1.8rem;
      border: 0;
      border-radius: 999px;
      background: transparent;
      color: var(--sl-color-gray-3);
      cursor: pointer;
      opacity: 0;
      transition: opacity 0.3s ease 0.12s, color 0.2s ease, background 0.2s ease;
    }
    .gv-search.is-open .gv-search__close {
      opacity: 1;
    }
    .gv-search__close:hover {
      color: var(--sl-color-white);
      background: color-mix(in srgb, var(--sl-color-gray-5) 45%, transparent);
    }

    /* ---------- Pagefind form, reskinned to sit inside the pill ---------- */
    .gv-search .pagefind-ui {
      width: 100%;
      font-family: var(--sl-font);
    }
    .gv-search .pagefind-ui__form {
      position: static;
      margin: 0;
    }
    .gv-search .pagefind-ui__form::before {
      display: none; /* we supply our own leading magnifier */
    }
    .gv-search .pagefind-ui__search-input {
      width: 100%;
      height: 2.2rem;
      padding: 0;
      border: 0;
      background: transparent;
      color: var(--sl-color-white);
      font-size: 0.95rem;
      font-weight: 400;
    }
    .gv-search .pagefind-ui__search-input::placeholder {
      color: var(--sl-color-gray-3);
    }
    .gv-search .pagefind-ui__search-input:focus {
      outline: none;
      box-shadow: none;
    }
    .gv-search .pagefind-ui__search-clear {
      display: none; /* our close button + Esc cover this */
    }
    .gv-search__devnote {
      position: absolute;
      top: calc(100% + 0.6rem);
      inset-inline-end: 0;
      width: max-content;
      max-width: 22rem;
      padding: 0.55rem 0.8rem;
      border: 1px solid var(--sl-color-hairline-light);
      border-radius: 0.7rem;
      background: var(--sl-color-bg-sidebar);
      color: var(--sl-color-gray-3);
      font-size: 0.78rem;
    }

    /* ---------- Results: a floating glass drawer under the pill ---------- */
    .gv-search .pagefind-ui__drawer {
      position: absolute;
      top: calc(100% + 0.6rem);
      inset-inline-end: 0;
      z-index: 60;
      width: min(30rem, 88vw);
      max-height: min(66vh, 30rem);
      overflow-y: auto;
      margin: 0;
      padding: 0.5rem;
      border: 1px solid var(--sl-color-gray-5);
      border-radius: 1rem;
      /* Opaque, and *lighter* than the page so it reads as an elevated panel
         (dark-mode elevation = lift toward white). Matches Starlight's modal. */
      background: var(--sl-color-gray-6);
      box-shadow: 0 24px 60px -22px rgba(0, 0, 0, 0.9);
      transform-origin: top right;
      animation: gvSearchDrop 0.34s var(--gv-ease, cubic-bezier(0.16, 0.7, 0.3, 1));
    }
    .gv-search .pagefind-ui__drawer.pagefind-ui__hidden {
      display: none;
    }
    .gv-search .pagefind-ui__results-area {
      width: 100%;
      padding: 0.25rem;
    }
    .gv-search .pagefind-ui__results {
      width: 100%;
    }
    .gv-search .pagefind-ui__message {
      padding: 0.5rem 0.6rem 0.7rem;
      font-size: 0.78rem;
      letter-spacing: 0.01em;
      color: var(--sl-color-gray-3);
    }
    /* Strip Pagefind's default card chrome for a clean, flat result list. */
    .gv-search .pagefind-ui__result {
      border: 0 !important;
      border-radius: 0.7rem;
      padding: 0.35rem 0.55rem !important;
      background: transparent !important;
    }
    .gv-search .pagefind-ui__result:hover,
    .gv-search .pagefind-ui__result:focus-within {
      background: color-mix(in srgb, var(--golavo-gold) 11%, transparent) !important;
    }
    .gv-search .pagefind-ui__result-inner {
      gap: 0.15rem !important;
      background: transparent !important;
    }
    .gv-search .pagefind-ui__result-title,
    .gv-search .pagefind-ui__result-nested {
      background: transparent !important;
      border: 0 !important;
      padding-inline-start: 0.1rem !important;
    }
    .gv-search .pagefind-ui__result-title:not(.pagefind-ui__result-nested *)::before,
    .gv-search .pagefind-ui__result-nested::before {
      display: none !important; /* drop the page-icon / tree diagram; keep it minimal */
    }
    .gv-search .pagefind-ui__result-nested {
      padding-inline-start: 0.7rem !important;
    }
    .gv-search .pagefind-ui__result-link {
      color: var(--sl-color-white);
      font-weight: 600;
    }
    .gv-search .pagefind-ui__result-excerpt {
      color: var(--sl-color-gray-2);
      font-size: 0.82rem;
    }
    .gv-search .pagefind-ui__result mark {
      color: var(--golavo-gold);
      background: transparent;
      font-weight: 700;
    }

    @keyframes gvSearchDrop {
      from {
        opacity: 0;
        transform: translateY(-6px) scale(0.97);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    /* ---------- Reduced motion ---------- */
    @media (prefers-reduced-motion: reduce) {
      .gv-search__toggle,
      .gv-search__field,
      .gv-search__glyph,
      .gv-search__glyph--lead,
      .gv-search__close {
        transition-duration: 0.01ms;
      }
      .gv-search .pagefind-ui__drawer {
        animation: none;
      }
    }
  }
</style>
