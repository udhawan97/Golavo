---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const repo = "udhawan97/Golavo";
const releases = `https://github.com/${repo}/releases`;
const latestRelease = `${releases}/latest`;
const releaseApi = `https://api.github.com/repos/${repo}/releases/latest`;
---

<section
  class="gv-install"
  data-reveal
  data-release-api={releaseApi}
  data-latest-release={latestRelease}
  aria-labelledby="gv-install-title"
>
  <div class="gv-install-head">
    <h2 id="gv-install-title" class="gv-stage-title">Three ways in. Everything stays local.</h2>
    <p>
      Use the browser UI from source, or install the desktop app with no Python
      or terminal required. The desktop buttons resolve directly to the newest
      stable files published by Golavo's release workflow.
    </p>
  </div>

  <div class="gv-install-grid">
    <article class="gv-install-card" data-install-platform="web">
      <span class="gv-install-icon" aria-hidden="true">⌁</span>
      <p class="gv-install-platform">macOS · Windows · Linux</p>
      <h3>Run in your browser</h3>
      <p>Clone the source, run one command, and Golavo opens at <code>127.0.0.1:5173</code>.</p>
      <a class="gv-install-button" href={`${base}/build-from-source/`}>
        See browser setup <span aria-hidden="true">→</span>
      </a>
      <span class="gv-install-meta">Python 3.12+ · Node 22+</span>
    </article>

    <article class="gv-install-card" data-install-platform="mac">
      <span class="gv-install-recommended" data-role="preferred-label" hidden>Best for this device</span>
      <span class="gv-install-icon" aria-hidden="true">⌘</span>
      <p class="gv-install-platform">Apple Silicon · macOS</p>
      <h3>Download the Mac app</h3>
      <p>Install from a DMG, drag Golavo to Applications, then open it locally.</p>
      <a id="golavo-download-mac" class="gv-install-button" href={latestRelease}>
        Download .dmg <span aria-hidden="true">↓</span>
      </a>
      <span class="gv-install-meta" data-role="mac-meta">Newest stable release</span>
    </article>

    <article class="gv-install-card" data-install-platform="win">
      <span class="gv-install-recommended" data-role="preferred-label" hidden>Best for this device</span>
      <span class="gv-install-icon" aria-hidden="true">⊞</span>
      <p class="gv-install-platform">x64 · Windows 10/11</p>
      <h3>Download the Windows app</h3>
      <p>Use the per-user EXE installer; an MSI is also available on every release.</p>
      <a id="golavo-download-win" class="gv-install-button" href={latestRelease}>
        Download .exe <span aria-hidden="true">↓</span>
      </a>
      <span class="gv-install-meta" data-role="win-meta">Newest stable release</span>
    </article>
  </div>

  <div class="gv-install-foot">
    <p id="golavo-release-status" aria-live="polite">
      Loading the latest stable installer links from GitHub Releases…
    </p>
    <p>
      Desktop installers are not yet OS-signed. Gatekeeper or SmartScreen will
      warn on first launch; verify the included <code>SHA256SUMS.txt</code> and follow the
      <a href={`${base}/installation/`}>installation guide</a>.
    </p>
    <a href={releases}>All releases &amp; checksums <span aria-hidden="true">↗</span></a>
  </div>
</section>

<script>
  interface GitHubAsset {
    name: string;
    size: number;
    browser_download_url: string;
  }

  interface GitHubRelease {
    tag_name: string;
    assets: GitHubAsset[];
  }

  const installSection = document.querySelector<HTMLElement>(".gv-install[data-release-api]");
  const releaseApi = installSection?.dataset.releaseApi ?? "";
  const latestRelease = installSection?.dataset.latestRelease ?? "";
  const formatSize = (bytes: number) => `${Math.round(bytes / 1024 / 1024)} MB`;
  const releaseStatus = document.getElementById("golavo-release-status");
  const nav = navigator as Navigator & { userAgentData?: { platform?: string } };
  const platform = (
    nav.userAgentData?.platform || navigator.platform || navigator.userAgent || ""
  ).toLowerCase();
  const preferred = platform.includes("mac") ? "mac" : platform.includes("win") ? "win" : "web";

  document.querySelectorAll("[data-install-platform]").forEach((card) => {
    if (card.getAttribute("data-install-platform") !== preferred) return;
    card.classList.add("is-preferred");
    const label = card.querySelector<HTMLElement>('[data-role="preferred-label"]');
    if (label) label.hidden = false;
  });

  const setDownload = (id: string, asset: GitHubAsset | undefined, metaRole: string, tag: string) => {
    if (!asset) return;
    const link = document.getElementById(id) as HTMLAnchorElement | null;
    if (link) link.href = asset.browser_download_url;
    const meta = document.querySelector(`[data-role="${metaRole}"]`);
    if (meta) meta.textContent = `${tag} · ${formatSize(asset.size)}`;
  };

  (async () => {
    try {
      const response = await fetch(releaseApi, {
        headers: { Accept: "application/vnd.github+json" },
      });
      if (!response.ok) throw new Error(`GitHub returned ${response.status}`);
      const release = await response.json() as GitHubRelease;
      const assets = Array.isArray(release.assets) ? release.assets : [];
      const mac = assets.find((asset) => asset.name.toLowerCase().endsWith(".dmg"));
      const win = assets.find((asset) => asset.name.toLowerCase().endsWith("-setup.exe"));
      setDownload("golavo-download-mac", mac, "mac-meta", release.tag_name);
      setDownload("golavo-download-win", win, "win-meta", release.tag_name);
      if (releaseStatus) {
        releaseStatus.textContent = mac && win
          ? `${release.tag_name} stable · direct installer links ready`
          : `${release.tag_name} stable · one or more installers are listed on the release page`;
      }
    } catch {
      if (releaseStatus) {
        releaseStatus.textContent = "Latest stable release · GitHub will show the available installers";
      }
      document.querySelectorAll<HTMLAnchorElement>("#golavo-download-mac, #golavo-download-win").forEach((link) => {
        link.href = latestRelease;
      });
    }
  })();
</script>

<style>
  /* Paper surfaces and named tokens only — no raw --golavo-gold on text
     (it measures 2.26 on the light ground and fails). See design.md. */
  .gv-install {
    position: relative;
    padding-block: clamp(var(--gv-space-2xl), 9vw, var(--gv-space-3xl));
    border-top: var(--gv-rule-stage) solid var(--sl-color-white);
  }
  .gv-install-head > p:last-child {
    max-width: 58ch;
    margin-top: var(--gv-space-md);
    color: var(--sl-color-gray-2);
    font-size: var(--gv-text-lg);
    line-height: 1.65;
  }
  .gv-install-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(17rem, 100%), 1fr));
    gap: var(--gv-space-sm);
    margin-top: var(--gv-space-xl);
  }
  .gv-install-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: clamp(var(--gv-space-md), 3vw, var(--gv-space-lg));
    overflow: hidden;
    border: var(--gv-rule-hair) solid var(--sl-color-hairline);
    border-radius: var(--gv-radius-surface);
    background: var(--gv-paper-2);
    transition: transform var(--gv-dur-short) var(--gv-ease-out),
      border-color var(--gv-dur-short) var(--gv-ease-out);
  }
  .gv-install-card:hover,
  .gv-install-card.is-preferred {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--gv-engine) 58%, var(--sl-color-hairline));
  }
  .gv-install-recommended {
    position: absolute;
    top: var(--gv-space-sm);
    right: var(--gv-space-sm);
    padding: var(--gv-space-3xs) var(--gv-space-2xs);
    border: var(--gv-rule-hair) solid
      color-mix(in srgb, var(--gv-engine) 55%, transparent);
    border-radius: var(--gv-radius-cta);
    color: var(--gv-engine);
    font-family: var(--gv-font-mono);
    font-size: var(--gv-text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .gv-install-icon {
    display: grid;
    width: 2.75rem;
    height: 2.75rem;
    place-items: center;
    border: var(--gv-rule-hair) solid var(--sl-color-hairline);
    border-radius: var(--gv-radius-cta);
    color: var(--gv-engine);
    background: var(--gv-ground);
    font-family: var(--gv-font-mono);
    font-size: 1.3rem;
  }
  .gv-install-platform {
    margin-top: var(--gv-space-md) !important;
    color: var(--sl-color-gray-3) !important;
    font-family: var(--gv-font-mono);
    font-size: var(--gv-text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .gv-install-card h3 {
    margin-top: var(--gv-space-3xs);
    color: var(--sl-color-white);
    font-family: var(--gv-font-display);
    font-weight: 600;
    font-size: var(--gv-text-lg);
  }
  .gv-install-card > p:not(.gv-install-platform) {
    margin-top: var(--gv-space-2xs);
    color: var(--sl-color-gray-2);
    font-size: var(--gv-text-md);
    line-height: 1.6;
  }
  .gv-install-button {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--gv-space-2xs);
    width: 100%;
    min-height: 48px;
    margin-top: auto;
    padding: var(--gv-space-xs) var(--gv-space-sm);
    border: var(--gv-rule-hair) solid var(--sl-color-hairline);
    border-radius: var(--gv-radius-cta);
    color: var(--sl-color-white) !important;
    background: var(--gv-ground);
    font-weight: 600;
    transition: border-color var(--gv-dur-short) var(--gv-ease-out);
  }
  .gv-install-button:hover {
    border-color: var(--gv-engine);
  }
  .gv-install-button:focus-visible {
    outline: 3px solid var(--gv-focus);
    outline-offset: 4px;
  }
  .gv-install-meta {
    min-height: 1.2rem;
    margin-top: var(--gv-space-2xs);
    color: var(--sl-color-gray-3);
    font-family: var(--gv-font-mono);
    font-size: var(--gv-text-xs);
  }
  .gv-install-foot {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(14rem, 100%), 1fr));
    gap: var(--gv-space-sm);
    align-items: center;
    margin-top: var(--gv-space-md);
    padding: var(--gv-space-sm) var(--gv-space-md);
    border-block: var(--gv-rule-hair) solid var(--sl-color-hairline);
    color: var(--sl-color-gray-3);
    font-size: var(--gv-text-sm);
    line-height: 1.55;
  }
  .gv-install-foot p { margin: 0; }
  .gv-install-foot > p:first-child {
    color: var(--sl-color-gray-1);
    font-family: var(--gv-font-mono);
  }
  .gv-install-foot > a {
    color: var(--sl-color-white);
    font-weight: 600;
  }
  @media (max-width: 46rem) {
    .gv-install-button { white-space: normal; }
  }
  @media (prefers-reduced-motion: reduce) {
    .gv-install-card { transition: none; }
  }
</style>
