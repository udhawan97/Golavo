---
/**
 * Golavo — bespoke landing hero (overrides Starlight's default Hero on the splash page).
 * Hallmark · genre: editorial · macrostructure: Narrative Workflow · design-system: design.md
 *
 * Theme: soccer · japan · zen. A hard-edged rising sun behind drifting seigaiha
 * waves, with the sumi brushstroke mark on the horizon — a woodblock composition,
 * not a gradient bloom. Left-biased, per the editorial genre. All motion honors
 * prefers-reduced-motion.
 */
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Seigaiha ground: the logo's concentric-circle motif tiled in two offset rows,
// drifting left one 128px unit for a seamless loop (matches the mark's kDrift).
const unit = 128;
const cols = Array.from({ length: 20 }, (_, i) => -unit + i * unit);
---

<section class="gh" aria-labelledby="gh-title">
  <div class="gh-atmos" aria-hidden="true">
    <!-- No background sun here: the mark already IS a disc with a rising sun.
         A second disc behind it is the same motif twice. The mark rises over
         the seigaiha horizon instead. -->

    <!-- The icon's seigaiha ground, opened into one clean landing-page horizon. -->
    <svg class="gh-waves" viewBox="0 0 2048 220" preserveAspectRatio="xMidYMax slice" fill="none">
      <defs>
        <g id="gh-wv" stroke="var(--gh-wave)" stroke-width="2.4">
          <circle cx="60" cy="60" r="58" fill="var(--gv-ground)" />
          <circle cx="60" cy="60" r="44" />
          <circle cx="60" cy="60" r="30" /><circle cx="60" cy="60" r="16" />
        </g>
      </defs>
      <g class="gh-waveDrift">
        {cols.map((x) => <use href="#gh-wv" x={x} y="66" />)}
        {cols.map((x) => <use href="#gh-wv" x={x + unit / 2} y="114" />)}
      </g>
    </svg>
  </div>

  <div class="gh-inner">
    <div class="gh-copy">
      <p class="gh-status gh-rise" style="--d:0ms">
        <span class="gh-status-dot"></span>v0.15.0 · unsigned pre-alpha · local-first
      </p>

      <p class="gh-eyebrow gh-rise" style="--d:80ms">The local-first football match cockpit</p>

      <h1 id="gh-title" class="gh-title">
        <span class="gh-line gh-rise" style="--d:160ms">The numbers remember everything.</span>
        <span class="gh-line gh-rise" style="--d:280ms">The beautiful game keeps the last word.</span>
      </h1>

      <p class="gh-sub gh-rise" style="--d:400ms">
        Open any match. Compare two genuinely different model voices, see the facts
        behind the fixture, and put an upcoming prediction on the record. The engine
        owns every number; optional AI can explain, but never edit.
      </p>

      <div class="gh-actions gh-rise" style="--d:520ms">
        <a class="gh-btn gh-btn--primary" href="#gv-install-title">
          Download or run locally
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a class="gh-btn gh-btn--ghost" href="#gv-stage-1">See the cockpit</a>
        <a class="gh-btn gh-btn--text" href="https://github.com/udhawan97/Golavo" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49 0-.24-.01-.87-.01-1.72-2.78.62-3.37-1.37-3.37-1.37-.45-1.18-1.11-1.5-1.11-1.5-.91-.63.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.36-2.22-.26-4.55-1.14-4.55-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05a9.36 9.36 0 015 0c1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.06.36.32.68.94.68 1.9 0 1.37-.01 2.48-.01 2.82 0 .27.18.6.69.49A10.26 10.26 0 0022 12.25C22 6.58 17.52 2 12 2z"/></svg>
          GitHub
        </a>
      </div>
    </div>

    <div class="gh-mark gh-rise" style="--d:200ms">
      <img class="gh-mark-img gh-mark-img--dark" src={`${base}/brand/golavo-mark-dark.svg`}
        alt="Golavo — a sumi brushstroke ball tracing the letter G into the top corner of a goal beneath a rising sun"
        width="220" height="220" loading="eager" decoding="async" />
      <img class="gh-mark-img gh-mark-img--light" src={`${base}/brand/golavo-mark-light.svg`}
        alt="" aria-hidden="true" width="220" height="220" loading="eager" decoding="async" />
    </div>
  </div>
</section>

<script>
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)");

  // Reveal-on-scroll for any element marked data-reveal (custom landing sections).
  // The hanko press hangs off the same .in class — no extra machinery.
  const revealables = document.querySelectorAll("[data-reveal]");
  if (revealables.length) {
    if (reduce.matches || !("IntersectionObserver" in window)) {
      revealables.forEach((el) => el.classList.add("in"));
    } else {
      try {
        const io = new IntersectionObserver(
          (entries, obs) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                (e.target as HTMLElement).style.setProperty(
                  "--rd",
                  `${(e.target as HTMLElement).dataset.reveal || "0"}ms`,
                );
                e.target.classList.add("in");
                obs.unobserve(e.target);
              }
            }
          },
          { threshold: 0.16, rootMargin: "0px 0px -8% 0px" },
        );
        revealables.forEach((el) => {
          io.observe(el);
          el.classList.add("gv-reveal-ready");
        });
      } catch {
        revealables.forEach((el) => el.classList.add("in"));
      }
    }
  }
</script>

<style>
  /* ---- Full-bleed break-out of Starlight's splash container ---- */
  .gh {
    position: relative;
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    padding: clamp(2rem, 5vh, 4rem) 1.5rem clamp(5rem, 9vh, 7rem);
    overflow: clip;
    isolation: isolate;
    /* theme-tuned atmosphere tokens (dark default) */
    --gh-wave: color-mix(in srgb, var(--gv-wave-ink) 32%, transparent);
  }
  :global([data-theme="light"]) .gh {
    --gh-wave: color-mix(in srgb, var(--gv-wave-ink) 20%, transparent);
  }

  /* ---- Atmosphere ---- */
  .gh-atmos {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
  }

  .gh-waves {
    position: absolute;
    left: 50%;
    bottom: -2px;
    translate: -50% 0;
    width: 100%;
    min-width: 1200px;
    height: clamp(120px, 16vh, 176px);
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 32%, #000 86%, transparent 100%);
    mask-image: linear-gradient(to bottom, transparent 0%, #000 32%, #000 86%, transparent 100%);
  }
  .gh-waveDrift {
    animation: ghDrift 20s linear infinite;
  }

  /* ---- Content: left-biased. Editorial heroes are not centred stacks. ---- */
  .gh-inner {
    position: relative;
    z-index: 1;
    width: min(1180px, 100%);
    margin-inline: auto;
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(0, 0.65fr);
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: center;
  }
  .gh-copy {
    min-width: 0;
  }

  /* Paper, not glass — no backdrop-filter anywhere in this brand. */
  .gh-status {
    display: inline-flex;
    align-items: center;
    gap: var(--gv-space-2xs);
    margin: 0 0 var(--gv-space-md);
    padding: var(--gv-space-3xs) var(--gv-space-xs);
    font-family: var(--gv-font-mono);
    font-size: var(--gv-text-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--sl-color-gray-2);
    border: var(--gv-rule-hair) solid var(--sl-color-gray-5);
    border-radius: var(--gv-radius-cta);
    background: var(--gv-paper-2);
  }
  .gh-status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--gv-engine);
  }

  .gh-eyebrow {
    margin: 0 0 var(--gv-space-2xs);
    font-family: var(--gv-font-mono);
    font-size: var(--gv-text-sm);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gv-engine);
  }

  /* Roman. Italic is body-copy emphasis only. */
  .gh-title {
    margin: 0;
    font-family: var(--gv-font-display);
    font-weight: 600;
    font-style: normal;
    line-height: 1.06;
    letter-spacing: -0.03em;
    font-size: clamp(2.1rem, 4.6vw, 3.9rem);
    color: var(--sl-color-white);
    text-wrap: balance;
    overflow-wrap: anywhere;
    min-width: 0;
  }
  .gh-line {
    display: block;
  }

  .gh-sub {
    margin: var(--gv-space-md) 0 0;
    max-width: 52ch;
    font-size: var(--gv-text-lg);
    line-height: 1.65;
    color: var(--sl-color-gray-2);
  }

  .gh-actions {
    margin-top: var(--gv-space-lg);
    display: flex;
    flex-wrap: wrap;
    gap: var(--gv-space-2xs);
    align-items: center;
  }

  /* Flat fill, 4px radius. A stamp, not a lozenge — gradient pills are banned. */
  .gh-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--gv-space-2xs);
    min-height: 46px;
    padding: var(--gv-space-xs) var(--gv-space-md);
    border: var(--gv-rule-hair) solid transparent;
    border-radius: var(--gv-radius-cta);
    font-weight: 600;
    font-size: var(--gv-text-md);
    text-decoration: none;
    white-space: nowrap;
    transition: transform var(--gv-dur-short) var(--gv-ease-out),
      background var(--gv-dur-short) var(--gv-ease-out),
      border-color var(--gv-dur-short) var(--gv-ease-out);
  }
  .gh-btn svg {
    transition: transform var(--gv-dur-short) var(--gv-ease-out);
  }
  .gh-btn--primary {
    color: var(--gv-seal-ink);
    background: var(--gv-seal);
    border-color: var(--gv-seal);
  }
  .gh-btn--primary:hover {
    transform: translateY(-2px);
    background: color-mix(in srgb, var(--gv-seal) 88%, var(--sl-color-white));
  }
  .gh-btn--primary:hover svg {
    transform: translateX(3px);
  }
  .gh-btn--ghost {
    color: var(--sl-color-white);
    border-color: var(--sl-color-gray-4);
    background: transparent;
  }
  .gh-btn--ghost:hover {
    transform: translateY(-2px);
    border-color: var(--gv-engine);
  }
  .gh-btn--text {
    color: var(--sl-color-gray-1);
    padding-inline: var(--gv-space-xs);
  }
  .gh-btn--text:hover {
    color: var(--sl-color-white);
  }
  .gh-btn:focus-visible {
    outline: 3px solid var(--gv-focus);
    outline-offset: 4px;
  }

  .gh-mark {
    justify-self: center;
    width: clamp(180px, 28vw, 330px);
    aspect-ratio: 1;
  }
  .gh-mark-img {
    width: 100%;
    height: 100%;
    display: block;
  }
  .gh-mark-img--light {
    display: none;
  }
  :global([data-theme="light"]) .gh-mark-img--dark {
    display: none;
  }
  :global([data-theme="light"]) .gh-mark-img--light {
    display: block;
  }

  /* ---- Entrance: one orchestrated sequence, then the page is still. ---- */
  .gh-rise {
    opacity: 0;
    transform: translateY(16px);
    animation: ghRise var(--gv-dur-long) var(--gv-ease-out) forwards;
    animation-delay: var(--d, 0ms);
  }

  @keyframes ghRise {
    to {
      opacity: 1;
      transform: none;
    }
  }
  @keyframes ghDrift {
    to {
      transform: translateX(-128px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gh-rise {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .gh-waveDrift {
      animation: none;
    }
  }

  @media (max-width: 60rem) {
    .gh-inner {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--gv-space-lg);
    }
    .gh-mark {
      grid-row: 1;
      justify-self: start;
      width: clamp(120px, 26vw, 170px);
    }
    .gh-sun {
      right: -10%;
      top: 2%;
      width: min(90vw, 420px);
    }
  }

  @media (max-width: 46rem) {
    .gh {
      padding-bottom: 3.5rem;
    }
    .gh-waves {
      bottom: -16px;
      height: 110px;
    }
    .gh-btn {
      white-space: normal;
    }
  }
</style>
