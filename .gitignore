# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini
# iCloud "Desktop & Documents" sync leaves duplicate " 2"/" 3" files
*\ 2
*\ 2.*
*\ 3
*\ 3.*

# ---- Session/runtime state (never version-controlled) ----
# The remember plugin writes logs, pids and timestamps here every session;
# tracking it churns the tree and is how iCloud dupes got committed before.
.remember/

# ---- Secrets / local config (NEVER commit real values) ----
.env
.env.*
!.env.example
*.local
.claude/
secrets/
*.key
*.pem
# ...but signing PUBLIC keys are meant to be committed:
!packaging/**/*.pub
!packs/**/*.pub

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ---- Node / UI / Docs ----
node_modules/
ui/dist/
docs-site/dist/
docs-site/.astro/
.pnpm-store/
*-debug.log*

# ---- Tauri / Rust ----
target/
desktop/gen/
desktop/src-tauri/gen/
# The frozen sidecar is a ~70MB build artifact copied in at build time, never committed.
desktop/src-tauri/binaries/
# Packaging build output (frozen sidecar + Tauri bundle) is regenerated by build.sh.
packaging/out/
packaging/build/

# ---- Golavo runtime data (user data + build output; never committed) ----
warehouse/
*.duckdb
*.duckdb.wal
*.parquet
golavo.db
golavo.db-*
ledger.db
ledger.db-*
backups/
data/raw/
data/snapshots/
packs/**/build/
# Frozen, lawful CC0 demo bundles ARE tracked:
!data/fixtures/
!data/fixtures/**
# The frozen CC0 match search index IS tracked (parquet is otherwise ignored):
!data/index/
!data/index/**

# ---- Packaging / release output ----
*.dmg
*.exe
*.msi
*.app/
*.tar.gz
SBOM*.json
SHA256SUMS*
*.minisig

# graphify knowledge graph (build artifact, regenerate with: graphify update .)
graphify-out/
